# ----------------------------------------------------------------------------
# Sprint V1 Validation — environment variables
# Copy this file to `.env.local` and fill in your Supabase project values.
# Find these in your Supabase dashboard: Project Settings → API
# ----------------------------------------------------------------------------

# Project URL (e.g. https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (server-only — NEVER expose to the browser).
# Required for background screenshot OCR (writes parsed values into check-ins).
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API key (server-only — NEVER expose to the browser). Powers two
# things: (1) screenshot OCR — reads Whoop / nutrition screenshots and fills the
# matching daily check-in fields; (2) the admin "Generate Coach Response" button
# — drafts a daily coaching decision for you to review, edit, and approve.
# Get one at https://console.anthropic.com → API Keys.
ANTHROPIC_API_KEY=

# OpenAI API key (server-only). Used for text-embedding-3-small to embed
# athlete memory notes for RAG retrieval. Get one at https://platform.openai.com → API Keys.
OPENAI_API_KEY=

# Optional: override the vision model used for OCR (defaults to claude-sonnet-4-6).
# OCR_MODEL=claude-sonnet-4-6

# Optional: override the model used to draft coach responses (defaults to
# claude-sonnet-4-6). Use claude-opus-4-8 for the highest-quality drafts.
# COACH_MODEL=claude-sonnet-4-6

# Secret that protects the cron endpoints (milestone reports). Set the SAME value
# here and in Vercel; Vercel Cron sends it automatically as a Bearer token. Use a
# long random string. Without it, the cron route refuses to run.
# CRON_SECRET=

# Public base URL of the app, used to build links in generated reports
# (e.g. https://your-app.vercel.app). Falls back to the Vercel deployment URL.
# NEXT_PUBLIC_APP_URL=

# Nutritionix Track API v2 (server-only — NEVER expose to the browser).
# Get credentials at https://developer.nutritionix.com → create a free account → create an app.
# Used for natural language food parsing and food search.
NUTRITIONIX_APP_ID=
NUTRITIONIX_APP_KEY=
