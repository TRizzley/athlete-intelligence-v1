# ----------------------------------------------------------------------------
# Sprint V1 — environment variables
# Copy this file to `.env.local` and fill in the values. Every variable the
# app reads is documented here; optional ones are commented out with their
# defaults noted.
# ----------------------------------------------------------------------------

# ── Supabase (Project Settings → API) ────────────────────────────────────────

# Project URL (e.g. https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe to expose to the browser). Inlined at build time.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (server-only — NEVER expose to the browser, never prefix
# with NEXT_PUBLIC_). Used by background OCR, WHOOP sync, coach generation,
# and cron routes to write across RLS.
SUPABASE_SERVICE_ROLE_KEY=

# ── AI ────────────────────────────────────────────────────────────────────────

# Anthropic API key (server-only). Powers screenshot OCR, coach drafts, chat,
# memory distillation, milestone reports, and prediction scoring.
# Get one at https://console.anthropic.com → API Keys.
ANTHROPIC_API_KEY=

# OpenAI API key (server-only). Used for text-embedding-3-small to embed
# athlete memory notes for retrieval. https://platform.openai.com → API Keys.
OPENAI_API_KEY=

# Optional model overrides (defaults shown).
# OCR_MODEL=claude-sonnet-4-6        # vision model for screenshot OCR
# COACH_MODEL=claude-sonnet-4-6      # coach drafts/chat/reports
# MEMORY_MODEL=claude-haiku-4-5-20251001  # memory distillation + scoring

# ── WHOOP OAuth (developer.whoop.com) ────────────────────────────────────────

WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=

# ── Cron / app URL ───────────────────────────────────────────────────────────

# Secret protecting the cron endpoints (reminders, whoop-sync, milestone
# reports). Set the SAME value here and in Vercel; Vercel Cron sends it as a
# Bearer token automatically. Long random string. Note: the pg_cron
# reminders-tick job in Supabase carries its own copy of this value — update
# both if you rotate it.
CRON_SECRET=

# Public base URL used to build links in generated reports
# (e.g. https://your-app.vercel.app). Falls back to VERCEL_URL, then
# http://localhost:3000.
# NEXT_PUBLIC_APP_URL=

# ── Push reminders (APNs) — DISABLED for Phase 1 ─────────────────────────────
# The reminders cron no-ops unless APNS_ENABLED=true. To turn push reminders
# on you also need an Apple Developer APNs auth key: set APNS_KEY_ID and
# APNS_KEY_P8 (the .p8 file contents) — see lib/push.ts.
# APNS_ENABLED=false
# APNS_BUNDLE_ID=com.sprintv1.app
# APNS_TEAM_ID=
# APNS_PRODUCTION=true

# Reminder timing (defaults shown): local hour to send the morning check-in
# reminder, and the timezone used to compute it.
# REMINDER_MORNING_HOUR=9
# REMINDER_TIMEZONE=America/New_York
