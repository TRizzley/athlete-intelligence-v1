# ----------------------------------------------------------------------------
# Sprint V1 Validation — environment variables
# Copy this file to `.env.local` and fill in your Supabase project values.
# Find these in your Supabase dashboard: Project Settings → API
# ----------------------------------------------------------------------------

# Project URL (e.g. https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (server-only — NEVER expose to the browser).
# Optional for this app: only used by server-side admin helpers if needed.
SUPABASE_SERVICE_ROLE_KEY=
